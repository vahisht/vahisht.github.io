                    <div id="bc-stack" style="position:absolute;transform:scale(0.65);transform-origin:top left;top:8px;left:10px;width:1320px;height:818px;font-family:'Segoe UI',-apple-system,BlinkMacSystemFont,sans-serif;font-size:11px;user-select:none;cursor:default;">
                        <svg id="wires-stack" style="position:absolute;top:0;left:0;width:1320px;height:818px;pointer-events:none;overflow:visible;" xmlns="http://www.w3.org/2000/svg"></svg>
                        <!-- Mapping -->
                        <div style="position:absolute;left:20px;top:200px;width:158px;border-radius:5px;overflow:visible;">
                            <div style="background:#1F4A64;height:24px;border-radius:5px 5px 0 0;display:flex;align-items:center;padding:0 8px;color:#fff;font-size:11px;font-weight:700">Mapping</div>
                            <div style="background:#3D3D3D;border-radius:0 0 5px 5px;overflow:visible;">
                                <div style="height:22px;display:flex;align-items:center;padding:0 10px 0 12px;position:relative;"><span style="color:#E8E8E8;font-size:10.5px">Vector</span><span data-sid="stk_map_vec_o" style="position:absolute;top:7px;right:-4px;width:8px;height:8px;border-radius:50%;background:#6363C7;border:1.5px solid #4545AA"></span></div>
                                <div style="height:22px;display:flex;align-items:center;padding:0 10px 0 12px;position:relative;background:rgba(0,0,0,0.12);"><span style="color:#888;font-size:10.5px">Location</span><span style="color:#555;font-size:9px;margin-left:auto">0, 0, 0</span></div>
                                <div style="height:22px;display:flex;align-items:center;padding:0 10px 0 12px;position:relative;"><span style="color:#888;font-size:10.5px">Rotation</span><span style="color:#555;font-size:9px;margin-left:auto">0, 0, 0</span></div>
                                <div style="height:22px;display:flex;align-items:center;padding:0 10px 0 12px;position:relative;background:rgba(0,0,0,0.12);border-radius:0 0 5px 5px;"><span style="color:#888;font-size:10.5px">Scale</span><span style="color:#555;font-size:9px;margin-left:auto">1, 1, 1</span></div>
                            </div>
                        </div>
                        <!-- Image Texture: Albedo -->
                        <div style="position:absolute;left:200px;top:10px;width:192px;border-radius:5px;overflow:visible;">
                            <div style="background:#1B4F6B;height:24px;border-radius:5px 5px 0 0;display:flex;align-items:center;padding:0 8px;color:#fff;font-size:11px;font-weight:700">Image Texture</div>
                            <div style="background:#3D3D3D;border-radius:0 0 5px 5px;overflow:visible;">
                                <div style="height:18px;background:#2E2E2E;display:flex;align-items:center;padding:0 6px;border-bottom:1px solid #222;"><span style="color:#777;font-size:9.5px">rock_albedo.png</span></div>
