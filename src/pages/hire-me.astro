    /* Timeline tooltip */
    .tl-bar::after {
        content: attr(data-tooltip);
        position: absolute;
        bottom: calc(100% + 6px);
        left: 50%;
        transform: translateX(-50%);
        background: #1e293b;
        color: #cbd5e1;
        font-size: 0.65rem;
        white-space: nowrap;
        padding: 3px 8px;
        border-radius: 4px;
        border: 1px solid #334155;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.15s;
        z-index: 50;
    }
    .tl-bar:hover::after {
        opacity: 1;
    }

    /* Hide label text if bar is too narrow (under ~40px visual width) */
    .tl-bar .tl-label {
        min-width: 0;
    }
    .tl-bar[style*="right: 9"] .tl-label,
    .tl-bar[style*="right: 8"] .tl-label {
        display: none;
    }

    /* Timeline sweep-in animation */
    #tl-reveal {
        clip-path: inset(0 100% 0 0);
        will-change: clip-path;
    }
</style>

<script>
    const DURATION = 2600; // ← animation speed in ms, adjust to preference

    const tlReveal    = document.getElementById('tl-reveal');
    const cursor      = document.getElementById('tl-cursor') as HTMLElement | null;
    const cursorYear  = document.getElementById('tl-cursor-year');
    const replayBtn   = document.getElementById('tl-replay') as HTMLElement | null;
    const labelWork   = document.getElementById('tl-label-work') as HTMLElement | null;
    const labelEdu    = document.getElementById('tl-label-edu') as HTMLElement | null;

    function fadeIn(el: HTMLElement | null, delay = 0) {
        if (!el) return;
        el.style.transition = `opacity 0.5s ${delay}ms`;
        el.style.opacity = '1';
    }

    if (tlReveal && cursor && cursorYear) {
        // Must match tlMinDate in frontmatter
        const tlMin = new Date(2009, 0, 1).getTime();
        const tlMax = Date.now();

        function pctToYear(pct: number): number {
            return new Date(tlMin + (pct / 100) * (tlMax - tlMin)).getFullYear();
        }
        function ease(t: number): number {
            return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
        }

        function runAnimation() {
            const start = performance.now();
            cursor!.style.transition = '';
            cursor!.style.opacity = '1';
            // Hide replay while animating
            if (replayBtn) { replayBtn.style.transition = 'none'; replayBtn.style.opacity = '0'; }

            function frame(now: number) {
                const raw = Math.min((now - start) / DURATION, 1);
                const pct = ease(raw) * 100;

                tlReveal!.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
                cursor!.style.left = `${pct}%`;
                cursorYear!.textContent = String(pctToYear(pct));

                if (raw < 1) {
                    requestAnimationFrame(frame);
                } else {
                    // Fully reveal and fade out cursor, fade in labels + replay
                    tlReveal!.style.clipPath = 'none';
                    cursor!.style.transition = 'opacity 0.5s';
                    cursor!.style.opacity = '0';
                    fadeIn(replayBtn, 300);
                }
            }
            requestAnimationFrame(frame);
        }

        const observer = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting) {
                runAnimation();
                observer.disconnect();
            }
        }, { threshold: 0.2 });
        observer.observe(document.getElementById('tl-container') ?? tlReveal);

        replayBtn?.addEventListener('click', () => {
            tlReveal!.style.clipPath = 'inset(0 100% 0 0)';
            runAnimation();
        });
    }

    // ── Side nav active section tracking ──
    const navItems = document.querySelectorAll<HTMLElement>('#side-nav .side-nav-item');
    const sections = ['intro', 'bragging', 'bragging-two', 'career', 'work-experience', 'education', 'hire-me-quest']
        .map(id => document.getElementById(id))
        .filter(Boolean) as HTMLElement[];

    // sections that map to a different nav item
    const sectionToNav: Record<string, string> = {
        'bragging-two': 'bragging',
        'work-experience': 'career',
        'education': 'career',
    };

    function setActive(id: string) {
        const navId = sectionToNav[id] ?? id;
        navItems.forEach(item => {
            item.classList.toggle('active', item.dataset.section === navId);
        });
    }

    function updateActiveSection() {
        const threshold = window.innerHeight * 0.45;
        let active = sections[0];
        for (const section of sections) {
            if (section.getBoundingClientRect().top <= threshold) {
                active = section;
            }
        }
        if (active) setActive(active.id);
    }

    window.addEventListener('scroll', updateActiveSection, { passive: true });
    updateActiveSection();
</script>
