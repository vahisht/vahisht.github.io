            <div class="flex flex-col md:flex-row gap-8 items-stretch">
                <!-- Left: text -->
                <div class="flex-1 flex flex-col">
                    <div class="flex-1"></div>
                    <div>
                    <h2 class="text-2xl font-semibold text-white mb-3 bragging-heading">The Stack</h2>
                    <p class="text-slate-400 leading-relaxed mb-4 text-justify">Between industry and academia, I've worked on a wide range of projects using both widely available technologies and heavily customized in-house tools.</p>

