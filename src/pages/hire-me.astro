    <script is:inline>
    (function () {
        var AOI_X1 = 992, AOI_Y1 = 681;
        var AOI_X2 = 1364, AOI_Y2 = 918;
        var FADE_LEFT_PX  = 1200; // px of fade from image left visible edge inward  — tune this
        var FADE_RIGHT_PX = 750;  // px of fade ending at slot right edge             — tune this

        var bg        = document.getElementById('ir-bg');
        var bgWrapper = document.getElementById('ir-bg-wrapper');
        var bgSharp   = document.getElementById('ir-bg-sharp');
        var slot      = document.getElementById('ir-slot');
        var section   = bg && bg.closest('section');

        function positionAll() {
            if (!section || !bg || !slot || !bg.naturalWidth) return;

            var aoiW = AOI_X2 - AOI_X1;
            var aoiH = AOI_Y2 - AOI_Y1;

            // Derive slot size from section width — stable anchor, no feedback loop
            var contentW = Math.min(section.offsetWidth - 64, 1400);
            var slotW    = Math.round(window.innerWidth < 768 ? contentW * 0.85 : contentW * 0.45);
            var slotH    = Math.max(280, Math.round(slotW * aoiH / aoiW * 0.85));
            slot.style.width     = slotW + 'px';
            slot.style.height    = slotH + 'px';
            slot.style.minHeight = '0';

            var sr = section.getBoundingClientRect();
            var fr = slot.getBoundingClientRect();
            var scale = Math.max(fr.width / aoiW, fr.height / aoiH);

            var imgW = bg.naturalWidth  * scale;
            var imgH = bg.naturalHeight * scale;
            var imgLeft = (fr.left - sr.left + fr.width  / 2) - (AOI_X1 + AOI_X2) / 2 * scale;
            var imgTop  = (fr.top  - sr.top  + fr.height / 2) - (AOI_Y1 + AOI_Y2) / 2 * scale;

            bg.style.maxWidth = 'none';
            bg.style.width  = imgW + 'px';
            bg.style.height = imgH + 'px';
            bg.style.left   = imgLeft + 'px';
            bg.style.top    = imgTop  + 'px';

            // Mask: left fade anchors to image left edge; right fade anchors to image right
            // visible edge (blurred image can extend beyond the slot to the right).
            if (bgWrapper) {
                var secW          = section.offsetWidth;
                var imgRight      = imgLeft + imgW;
                var leftFadeStart = Math.max(0, imgLeft);                    // image visible left edge
                var leftFadeEnd   = leftFadeStart + FADE_LEFT_PX;            // fully opaque by here
                var rightFadeEnd  = Math.min(secW, imgRight);                // transparent at image/section right
                var rightFadeStart = Math.max(leftFadeEnd, rightFadeEnd - FADE_RIGHT_PX);
                var msk = 'linear-gradient(to right, transparent 0px, transparent ' + Math.round(leftFadeStart) + 'px, black ' + Math.round(leftFadeEnd) + 'px, black ' + Math.round(rightFadeStart) + 'px, transparent ' + Math.round(rightFadeEnd) + 'px)';
                bgWrapper.style.maskImage = msk;
                bgWrapper.style.webkitMaskImage = msk;
            }

            // Sharp image: same position, clip-path cuts it to exactly the slot area
            if (bgSharp) {
                bgSharp.style.maxWidth = 'none';
                bgSharp.style.width  = imgW + 'px';
                bgSharp.style.height = imgH + 'px';
                bgSharp.style.left   = imgLeft + 'px';
                bgSharp.style.top    = imgTop  + 'px';
                var cTop    = Math.max(0, (fr.top    - sr.top)    - imgTop);
                var cLeft   = Math.max(0, (fr.left   - sr.left)   - imgLeft);
                var cRight  = Math.max(0, (imgLeft   + imgW)      - (fr.right  - sr.left));
                var cBottom = Math.max(0, (imgTop    + imgH)      - (fr.bottom - sr.top));
                bgSharp.style.clipPath = 'inset(' + cTop + 'px ' + cRight + 'px ' + cBottom + 'px ' + cLeft + 'px)';
            }
        }

        function init() {
            positionAll();
        }

        if (bg.complete && bg.naturalWidth) {
            init();
        } else {
            bg.addEventListener('load', init);
        }
        window.addEventListener('resize', positionAll);
    })();
    </script>

