    /* Neon-tube strike hover (DS2): the button flickers on like an old fluorescent
       light — irregular opacity stutter + a hot white border glow on each strike,
       settling into a steady glow. White here (papaya zone); cyan on dark pages.
       Mouse / fine-pointer only. */
    @media (hover: hover) and (pointer: fine) {
        .intro-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 0 0 1.5px rgba(255, 255, 255, 0.75), 0 0 10px rgba(255, 255, 255, 0.4);
            animation: neon-strike 0.4s linear 1;
        }
    }
    @media (prefers-reduced-motion: reduce) {
        .intro-btn:hover { animation: none; }
    }
    @keyframes neon-strike {
        0%   { opacity: 0.35; box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
        14%  { opacity: 1;    box-shadow: 0 0 0 2px #fff, 0 0 18px rgba(255, 255, 255, 0.9); }
        26%  { opacity: 0.3;  box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
        40%  { opacity: 1;    box-shadow: 0 0 0 2px #fff, 0 0 20px rgba(255, 255, 255, 0.95); }
        /* opacity stays at 1 from here — only the glow eases down to its resting state */
        100% { opacity: 1;    box-shadow: 0 0 0 1.5px rgba(255, 255, 255, 0.75), 0 0 10px rgba(255, 255, 255, 0.4); }
    }

    /* Photo anchored to the section's bottom edge. Drop an <img> inside .intro-photo
