---
import Layout from "../layout/Layout.astro";
import workData from "../data/work_experience.json";
import eduData from "../data/education.json";

const MONTHS = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];

function parseYM(ym: string): Date {
    const [y, m] = ym.split("-").map(Number);
    return new Date(y, m - 1, 1);
}

function formatYM(ym: string): string {
    const [y, m] = ym.split("-").map(Number);
    return `${MONTHS[m - 1]} ${y}`;
}

function diffMonths(start: Date, end: Date): number {
    return (end.getFullYear() - start.getFullYear()) * 12 + (end.getMonth() - start.getMonth()) + 1;
}

function formatDuration(months: number): string {
    const y = Math.floor(months / 12);
    const m = months % 12;
    const parts: string[] = [];
    if (y > 0) parts.push(`${y} yr${y !== 1 ? "s" : ""}`);
    if (m > 0) parts.push(`${m} mo`);
    return parts.join(" ");
}

const now = new Date();

const companies = workData.work_experience.map((company) => {
    const starts = company.roles.map(r => parseYM(r.start));
    const ends   = company.roles.map(r => r.end ? parseYM(r.end) : now);
    const minStart = starts.reduce((a, b) => a < b ? a : b);
    const maxEnd   = ends.reduce((a, b) => a > b ? a : b);
    const totalMonths = diffMonths(minStart, maxEnd);
    return { ...company, computedDuration: formatDuration(totalMonths) };
});
---

<Layout title="Hire Me">

    <!-- Quick-nav -->
    <nav class="w-full py-6" style="background: #0f172a;">
        <div class="mx-auto px-8 flex flex-col gap-3" style="max-width: 1400px;">
            <a href="#work-experience" class="text-sm text-slate-400 hover:text-white transition-colors">Work Experience</a>
            <a href="#education" class="text-sm text-slate-400 hover:text-white transition-colors">Education</a>
        </div>
    </nav>

    <!-- Work Experience -->
    <section id="work-experience" class="min-w-screen min-h-screen py-16 px-8" style="background: #020617;">
        <div class="mx-auto" style="max-width: 1400px;">

            <h1 class="text-3xl font-light text-slate-200 mb-16 tracking-wide">Work Experience</h1>

            <div class="relative flex flex-col gap-12">

                <div class="absolute top-2 bottom-2 w-px bg-slate-700" style="left: 4rem;"></div>

                {companies.map((company) => (
                    <div class="flex items-stretch">

                        <div class="flex-none" style="width: 4rem;"></div>

                        <div class="relative flex-none flex items-center" style="width: 2.5rem;">
                            {company.logo ? (
                                <img src={`/${company.logo}`} alt={company.company} class="absolute left-0 -translate-x-1/2 z-10 rounded object-contain bg-[#020617]" style="width: 2rem; height: 2rem;" />
                            ) : (
                                <div class="absolute left-0 w-3 h-3 rounded-full bg-white -translate-x-1/2 z-10"></div>
                            )}
                        </div>

                        <div class="flex-none flex flex-col justify-center" style="width: 13rem;">
                            <div class="flex items-center">
                                <span class="font-bold text-white leading-snug" style="font-size: 1.1rem;">{company.company}</span>
                            </div>
                            <span class="text-slate-600 mt-1 uppercase tracking-wider" style="font-size: 0.8rem; letter-spacing: 0.08em;">{company.computedDuration}</span>
                            {company.recommendation && (
                                <a href={`/${company.recommendation}`} target="_blank" class="text-slate-500 text-xs mt-2 hover:text-slate-300 transition-colors underline underline-offset-2">Letter of Recommendation</a>
                            )}
                        </div>

                        <div class="flex-none flex items-center" style="width: 4rem;">
                            <div class="w-full h-px bg-slate-700"></div>
                        </div>

                        <div class="flex flex-1 items-stretch">

                            <div class="flex-none self-stretch border-l border-t border-b border-slate-700" style="width: 1.5rem;"></div>

                            <div class="flex-1 flex flex-col">
                                {company.roles.map((role) => {
                                    return (
                                        <div class="flex items-start gap-10 py-6 px-6">

                                            <div class="flex-none" style="width: 18rem;">
                                                <p class="font-semibold text-white" style="font-size: 1.35rem;">{role.title}</p>
                                                <p class="text-slate-500 mt-1" style="font-size: 0.8rem;">
                                                    {formatYM(role.start)} – {role.current ? "Present" : formatYM(role.end!)} · <span class={`uppercase ${role.type === "full-time" ? "text-blue-400" : role.type === "part-time" ? "text-orange-400" : "text-green-400"}`}>{role.type}</span>
                                                </p>
                                                {role.location && <p class="text-slate-600 italic mt-0.5" style="font-size: 0.69rem;">{role.location}</p>}
                                            </div>

                                            <div class="flex-1 description text-slate-400 text-sm leading-relaxed" set:html={role.description} />

                                        </div>
                                    );
                                })}
                            </div>

                        </div>

                    </div>
                ))}

            </div>

        </div>
    </section>

    <!-- Education -->
    <section id="education" class="min-w-screen py-16 px-8" style="background: #020617;">
        <div class="mx-auto" style="max-width: 1400px;">

            <h1 class="text-3xl font-light text-slate-200 mb-16 tracking-wide">Education</h1>

            <div class="relative flex flex-col gap-12">

                <div class="absolute top-2 bottom-2 w-px bg-slate-700" style="left: 4rem;"></div>

                {eduData.education.map((entry) => (
                    <div class="flex items-center">

                        <div class="flex-none" style="width: 4rem;"></div>

                        <div class="relative flex-none flex items-center" style="width: 2.5rem;">
                            {entry.logo ? (
                                <img src={`/${entry.logo}`} alt={entry.institution} class="absolute left-0 -translate-x-1/2 z-10 rounded object-contain bg-[#020617]" style="width: 2rem; height: 2rem;" />
                            ) : (
                                <div class="absolute left-0 w-3 h-3 rounded-full bg-white -translate-x-1/2 z-10"></div>
                            )}
                        </div>

                        <div class="flex-none flex flex-col justify-center" style="width: 13rem;">
                            <span class="font-bold text-white leading-snug whitespace-nowrap" style="font-size: 1.1rem;">{entry.institution}</span>
                            {entry.faculty && <span class="text-slate-400 mt-0.5" style="font-size: 1.0rem;">{entry.faculty}</span>}
                        </div>

                        <div class="flex items-start gap-10 py-2" style="padding-left: 7rem;">
                            <div class="flex-none" style="width: 18rem;">
                                <p class="font-semibold text-white" style="font-size: 1.25rem;">{entry.degree}</p>
                                <p class="text-slate-400 mt-0.5" style="font-size: 0.8rem;">{entry.field}</p>
                                <p class="text-slate-500 mt-1" style="font-size: 0.8rem;">
                                    {entry.start} – {entry.current ? "Present" : entry.end}
                                </p>
                            </div>

                            <div class="flex-1 description text-slate-400 text-sm leading-relaxed" set:html={entry.description} />
                        </div>

                    </div>
                ))}

            </div>

        </div>
    </section>

</Layout>

<style>
    .description p + p {
        margin-top: 0.75rem;
    }
</style>
