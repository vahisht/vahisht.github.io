---
import Layout from "../layout/Layout.astro";
import TrianglePattern from "../components/TrianglePattern.svelte";
import workData from "../data/work_experience.json";
import eduData from "../data/education.json";

const MONTHS = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];

function parseYM(ym: string): Date {
    const [y, m] = ym.split("-").map(Number);
    return new Date(y, m - 1, 1);
}

function formatYM(ym: string): string {
    const [y, m] = ym.split("-").map(Number);
    return `${MONTHS[m - 1]} ${y}`;
}

function diffMonths(start: Date, end: Date): number {
    return (end.getFullYear() - start.getFullYear()) * 12 + (end.getMonth() - start.getMonth()) + 1;
}

function formatDuration(months: number): string {
    const y = Math.floor(months / 12);
    const m = months % 12;
    const parts: string[] = [];
    if (y > 0) parts.push(`${y} yr${y !== 1 ? "s" : ""}`);
    if (m > 0) parts.push(`${m} mo`);
    return parts.join(" ");
}

function slugify(s: string): string {
    return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

function processDescription(html: string): string {
    return html.replace(/\*/g, '<sup style="color: #f59e0b; font-size: 1em; opacity: 0.85; letter-spacing: 0; vertical-align: -0.1em; margin-left: 1px; font-weight: 600;">*</sup>');
}

const now = new Date();

const companies = workData.work_experience.map((company) => {
    const starts = company.roles.map(r => parseYM(r.start));
    const ends   = company.roles.map(r => r.end ? parseYM(r.end) : now);
    const minStart = starts.reduce((a, b) => a < b ? a : b);
    const maxEnd   = ends.reduce((a, b) => a > b ? a : b);
    const totalMonths = diffMonths(minStart, maxEnd);
    return { ...company, computedDuration: formatDuration(totalMonths), tlStart: minStart, tlEnd: maxEnd };
});

// Horizontal timeline
const tlMinDate = new Date(2009, 0, 1);
const tlTotalMs = now.getTime() - tlMinDate.getTime();
function tlPct(date: Date): number {
    return Math.max(0, Math.min(100, ((date.getTime() - tlMinDate.getTime()) / tlTotalMs) * 100));
}
// 0=Urus, 1=Google, 2=CTU, 3=Snap, 4=Neit
const WORK_COLORS =      ["#7c3aed", "#4285F4", "#003DA5", "#FFFC00", "#b8c99e"];
const WORK_TEXT_COLORS = ["#ffffff", "#ffffff", "#ffffff", "#000000", "#000000"];
const companyTimeline = companies.map((c, i) => {
    const startY = c.tlStart.getFullYear();
    const endY   = c.tlEnd <= now ? c.tlEnd.getFullYear() : null;
    const tooltip = `${c.company} · ${startY}–${endY ?? "present"}`;
    return {
        label: c.company,
        shortLabel: c.company.includes("Czech Technical") ? "CTU" : c.company.split(/[\s,]+/)[0],
        tooltip,
        left: tlPct(c.tlStart),
        right: 100 - tlPct(c.tlEnd),
        color: WORK_COLORS[i] ?? "#475569",
        textColor: WORK_TEXT_COLORS[i] ?? "#ffffff",
        anchor: `work-${slugify(c.company)}`,
    };
});
function shortDegree(degree: string): string {
    if (degree.includes("Doctor") || degree.includes("PhD")) return "PhD";
    if (degree.includes("Master")) return "MSc";
    if (degree.includes("Bachelor")) return "BSc";
    return "HS";
}
const EDU_COLORS = ["#059669","#10b981","#34d399","#6b7280"];
const eduTimeline = eduData.education.map((e, i) => {
    const startYear = parseInt(e.start);
    const endYear   = parseInt(e.end);
    const start = new Date(startYear, 6, 1);  // mid-year
    const end   = e.current ? now : new Date(endYear, 6, 1);  // mid-year
    const tooltip = `${e.institution} · ${e.degree} · ${e.field} · ${startYear}–${e.current ? "present" : endYear}`;
    return { label: e.degree, shortLabel: shortDegree(e.degree), tooltip, left: tlPct(start), right: 100 - tlPct(end), color: EDU_COLORS[i] ?? "#6b7280", anchor: `edu-${slugify(e.institution)}` };
});
const tlTickYears = [2010, 2012, 2014, 2016, 2018, 2020, 2022, 2024, 2026];
