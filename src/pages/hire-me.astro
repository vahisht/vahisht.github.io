---
import Layout from "../layout/Layout.astro";
import workData from "../data/work_experience.json";
import eduData from "../data/education.json";

const MONTHS = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];

function parseYM(ym: string): Date {
    const [y, m] = ym.split("-").map(Number);
    return new Date(y, m - 1, 1);
}

function formatYM(ym: string): string {
    const [y, m] = ym.split("-").map(Number);
    return `${MONTHS[m - 1]} ${y}`;
}

function diffMonths(start: Date, end: Date): number {
    return (end.getFullYear() - start.getFullYear()) * 12 + (end.getMonth() - start.getMonth()) + 1;
}

function formatDuration(months: number): string {
    const y = Math.floor(months / 12);
    const m = months % 12;
    const parts: string[] = [];
    if (y > 0) parts.push(`${y} yr${y !== 1 ? "s" : ""}`);
    if (m > 0) parts.push(`${m} mo`);
    return parts.join(" ");
}

function slugify(s: string): string {
    return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}

const now = new Date();

const companies = workData.work_experience.map((company) => {
    const starts = company.roles.map(r => parseYM(r.start));
    const ends   = company.roles.map(r => r.end ? parseYM(r.end) : now);
    const minStart = starts.reduce((a, b) => a < b ? a : b);
    const maxEnd   = ends.reduce((a, b) => a > b ? a : b);
    const totalMonths = diffMonths(minStart, maxEnd);
    return { ...company, computedDuration: formatDuration(totalMonths), tlStart: minStart, tlEnd: maxEnd };
});

// Horizontal timeline
const tlMinDate = new Date(2009, 0, 1);
const tlTotalMs = now.getTime() - tlMinDate.getTime();
function tlPct(date: Date): number {
    return Math.max(0, Math.min(100, ((date.getTime() - tlMinDate.getTime()) / tlTotalMs) * 100));
}
// 0=Urus, 1=Google, 2=CTU, 3=Snap, 4=Neit
const WORK_COLORS =      ["#7c3aed", "#4285F4", "#003DA5", "#FFFC00", "#b8c99e"];
const WORK_TEXT_COLORS = ["#ffffff", "#ffffff", "#ffffff", "#000000", "#000000"];
const companyTimeline = companies.map((c, i) => {
    const startY = c.tlStart.getFullYear();
    const endY   = c.tlEnd <= now ? c.tlEnd.getFullYear() : null;
    const tooltip = `${c.company} · ${startY}–${endY ?? "present"}`;
    return {
        label: c.company,
        shortLabel: c.company.includes("Czech Technical") ? "CTU" : c.company.split(/[\s,]+/)[0],
        tooltip,
        left: tlPct(c.tlStart),
        right: 100 - tlPct(c.tlEnd),
        color: WORK_COLORS[i] ?? "#475569",
        textColor: WORK_TEXT_COLORS[i] ?? "#ffffff",
        anchor: `work-${slugify(c.company)}`,
    };
});
function shortDegree(degree: string): string {
    if (degree.includes("Doctor") || degree.includes("PhD")) return "PhD";
    if (degree.includes("Master")) return "MSc";
    if (degree.includes("Bachelor")) return "BSc";
    return "HS";
}
const EDU_COLORS = ["#059669","#10b981","#34d399","#6b7280"];
const eduTimeline = eduData.education.map((e, i) => {
    const startYear = parseInt(e.start);
    const endYear   = parseInt(e.end);
    const start = new Date(startYear, 6, 1);  // mid-year
    const end   = e.current ? now : new Date(endYear, 6, 1);  // mid-year
    const tooltip = `${e.institution} · ${e.degree} · ${e.field} · ${startYear}–${e.current ? "present" : endYear}`;
    return { label: e.degree, shortLabel: shortDegree(e.degree), tooltip, left: tlPct(start), right: 100 - tlPct(end), color: EDU_COLORS[i] ?? "#6b7280", anchor: `edu-${slugify(e.institution)}` };
});
const tlTickYears = [2010, 2012, 2014, 2016, 2018, 2020, 2022, 2024, 2026];
---

<Layout title="Hire Me">

    <!-- Introduction -->
    <section class="w-full py-16 px-8" style="background: #020617;">
        <div class="mx-auto" style="max-width: 1400px;">
            <h1 class="text-center text-4xl font-light text-white mb-10 tracking-wide">Name</h1>
            <div class="flex flex-col md:flex-row gap-0 items-stretch">
                <!-- Left: bio -->
                <div class="flex-1 text-slate-400 leading-relaxed pr-0 md:pr-12" style="font-size: 0.95rem;">
                    <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas. Vestibulum tortor quam, feugiat vitae, ultricies eget, tempor sit amet, ante.</p>
                    <p class="mt-4">Donec eu libero sit amet quam egestas semper. Aenean ultricies mi vitae est. Mauris placerat eleifend leo. Quisque sit amet est et sapien ullamcorper pharetra.</p>
                    <p class="mt-4">Vestibulum erat wisi, condimentum sed, commodo vitae, ornare sit amet, wisi. Aenean fermentum, elit eget tincidunt condimentum, eros ipsum rutrum orci, sagittis tempus lacus enim ac dui.</p>
                </div>
                <!-- Right: photo placeholder -->
                <div class="flex-1 flex items-center justify-center pl-0 md:pl-12">
                    <div class="w-full flex items-center justify-center rounded-lg border border-slate-700" style="height: 280px; background: #0f172a;">
                        <span class="text-slate-600 text-sm">Photo placeholder</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick-nav -->
    <nav class="w-full py-8 px-8" style="background: #0f172a; border-bottom: 1px solid #1e293b;">
        <div class="mx-auto flex flex-col" style="max-width: 1400px;">
            <a href="#bragging" class="group flex items-center gap-4 py-3 text-slate-500 hover:text-white transition-colors duration-150">
                <span class="w-5 h-px bg-slate-700 group-hover:bg-white group-hover:w-8 transition-all duration-200"></span>
                <span class="text-sm tracking-wide">Highlights</span>
            </a>
            <a href="#career" class="group flex items-center gap-4 py-3 text-slate-500 hover:text-white transition-colors duration-150">
                <span class="w-5 h-px bg-slate-700 group-hover:bg-white group-hover:w-8 transition-all duration-200"></span>
                <span class="text-sm tracking-wide">Career at a Glance</span>
            </a>
            <a href="#work-experience" class="group flex items-center gap-4 py-3 text-slate-500 hover:text-white transition-colors duration-150">
                <span class="w-5 h-px bg-slate-700 group-hover:bg-white group-hover:w-8 transition-all duration-200"></span>
                <span class="text-sm tracking-wide">Work Experience</span>
            </a>
            <a href="#education" class="group flex items-center gap-4 py-3 text-slate-500 hover:text-white transition-colors duration-150">
                <span class="w-5 h-px bg-slate-700 group-hover:bg-white group-hover:w-8 transition-all duration-200"></span>
                <span class="text-sm tracking-wide">Education</span>
            </a>
            <a href="#hire-me-quest" class="group flex items-center gap-4 py-3 text-indigo-400 hover:text-indigo-300 transition-colors duration-150">
                <span class="w-5 h-px bg-indigo-700 group-hover:bg-indigo-400 group-hover:w-8 transition-all duration-200"></span>
                <span class="text-sm tracking-wide font-medium">Contact Me</span>
            </a>
        </div>
    </nav>

    <!-- Bragging One -->
    <section id="bragging" class="w-full py-16 px-8" style="background: #0a1628;">
        <div class="mx-auto" style="max-width: 1400px;">
            <div class="flex flex-col md:flex-row gap-12 items-center">
                <!-- Left: text -->
                <div class="flex-1">
                    <h2 class="text-2xl font-semibold text-white mb-3">Bragging One</h2>
                    <p class="text-slate-400 leading-relaxed">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas. Vestibulum tortor quam, feugiat vitae, ultricies eget, tempor sit amet, ante.</p>
                    <p class="text-slate-400 leading-relaxed mt-3">Donec eu libero sit amet quam egestas semper. Aenean ultricies mi vitae est. Mauris placerat eleifend leo.</p>
                </div>
                <!-- Right: image/video placeholder -->
                <div class="flex-none flex items-center justify-center rounded-lg border border-slate-700" style="width: 420px; height: 260px; background: #0f172a;">
                    <span class="text-slate-600 text-sm">Image / video placeholder</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Bragging Two -->
    <section class="w-full py-16 px-8" style="background: #0d0d1f;">
        <div class="mx-auto" style="max-width: 1400px;">
            <div class="flex flex-col md:flex-row-reverse gap-12 items-center">
                <!-- Right (visually left due to row-reverse): text -->
                <div class="flex-1">
                    <h2 class="text-2xl font-semibold text-white mb-3">Bragging Two</h2>
                    <p class="text-slate-400 leading-relaxed">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas. Vestibulum tortor quam, feugiat vitae, ultricies eget, tempor sit amet, ante.</p>
                    <p class="text-slate-400 leading-relaxed mt-3">Donec eu libero sit amet quam egestas semper. Aenean ultricies mi vitae est. Mauris placerat eleifend leo.</p>
                </div>
                <!-- Left: image/video placeholder -->
                <div class="flex-none flex items-center justify-center rounded-lg border border-slate-700" style="width: 420px; height: 260px; background: #0f172a;">
                    <span class="text-slate-600 text-sm">Image / video placeholder</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Horizontal Timeline -->
    <section id="career" class="w-full py-10 px-8" style="background: #020617;">
        <div class="mx-auto" style="max-width: 1400px;">

        <h1 class="text-3xl font-light text-slate-200 mb-16 tracking-wide">Career at a Glance</h1>

            <!-- outer wrapper: margin-left makes room for WORK/EDU labels -->
            <div class="relative" style="margin-left: 2.5rem;" id="tl-container">

                <!-- WORK/EDU labels: siblings to tl-reveal so they can fade in separately -->
                <span id="tl-label-work" class="absolute text-slate-300 uppercase tracking-widest" style="font-size: 0.6rem; right: calc(100% + 6px); top: 0; height: 28px; display: flex; align-items: center;">WORK</span>
                <span id="tl-label-edu" class="absolute text-slate-300 uppercase tracking-widest" style="font-size: 0.6rem; right: calc(100% + 6px); top: 60px; height: 28px; display: flex; align-items: center;">EDU</span>

                <div id="tl-reveal" class="relative">

                <!-- Background grid lines (aligned with bars) -->
                <div class="absolute inset-0 pointer-events-none">
                    {tlTickYears.map(y => {
                        const pct = tlPct(new Date(y, 0, 1));
                        return <div class="absolute top-0 bottom-0 w-px" style={`left: ${pct}%; background: rgba(255,255,255,0.04);`}></div>;
                    })}
                </div>

                <!-- WORK row -->
                <div class="relative" style="height: 28px; margin-bottom: 8px;">
                    {companyTimeline.map((c) => (
                        <a
                            href={`#${c.anchor}`}
                            class="tl-bar absolute inset-y-0 flex items-center justify-center cursor-pointer transition-opacity hover:opacity-75"
                            style={`left: ${c.left}%; right: ${c.right}%; background: ${c.color}; border-radius: 4px; overflow: hidden;`}
                            data-tooltip={c.tooltip}
                            title={c.tooltip}
                        >
                            <span style={`font-size: 0.75rem; color: ${c.textColor}; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding: 0 4px;`}>{c.shortLabel}</span>
                        </a>
                    ))}
                </div>

                <!-- Axis row -->
                <div class="relative" style="height: 16px;">
                    <div class="absolute left-0 right-0" style="top: 50%; height: 2px; background: #475569; transform: translateY(-50%);"></div>
                    {tlTickYears.map(y => {
                        const pct = tlPct(new Date(y, 0, 1));
                        return <span class="absolute text-slate-300 -translate-x-1/2 -translate-y-1/2 px-0.5" style={`left: ${pct}%; top: 50%; font-size: 0.65rem; background: #020617;`}>{y}</span>;
                    })}
                </div>

                <!-- EDU row -->
                <div class="relative" style="height: 28px; margin-top: 8px;">
                    {eduTimeline.map((e) => (
                        <a
                            href={`#${e.anchor}`}
                            class="tl-bar absolute inset-y-0 flex items-center justify-center cursor-pointer transition-opacity hover:opacity-75"
                            style={`left: ${e.left}%; right: ${e.right}%; background: ${e.color}; border-radius: 4px; overflow: hidden;`}
                            data-tooltip={e.tooltip}
                            title={e.tooltip}
                        >
                            <span style="font-size: 0.75rem; color: rgba(255,255,255,0.9); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding: 0 4px;">{e.shortLabel}</span>
                        </a>
                    ))}
                </div>
                </div>

                <!-- Cursor: sibling to tl-reveal so it is not clipped -->
                <div id="tl-cursor" class="absolute pointer-events-none" style="top: 0; bottom: 0; left: 0; width: 2px; background: rgba(255,255,255,0.85); z-index: 30; opacity: 0;">
                    <span id="tl-cursor-year" style="position: absolute; top: -28px; left: 50%; transform: translateX(-50%); font-size: 0.85rem; font-weight: 600; color: white; white-space: nowrap; background: rgba(2,6,23,0.9); padding: 2px 8px; border-radius: 4px; border: 1px solid rgba(255,255,255,0.35);"></span>
                </div>

                <!-- Replay button: below timeline, flush right, fades in after animation -->
                <div class="flex justify-end" style="margin-top: 6px;">
                    <button id="tl-replay" title="Replay animation" style="display: flex; align-items: center; gap: 4px; font-size: 0.65rem; color: #94a3b8; background: none; border: 1px solid #334155; border-radius: 4px; padding: 2px 8px; cursor: pointer; opacity: 0; transition: color 0.15s, border-color 0.15s;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.33"/></svg>
                        replay
                    </button>
                </div>

            </div>
        </div>
    </section>

    <!-- Work Experience -->
    <section id="work-experience" class="w-full min-h-screen py-16 px-4 md:px-8" style="background: #020617;">
        <div class="mx-auto" style="max-width: 1400px;">

            <h1 class="text-3xl font-light text-slate-200 mb-16 tracking-wide">Work Experience</h1>

            <div class="relative flex flex-col gap-12">

                <div class="absolute top-2 bottom-2 w-px bg-slate-700 hidden md:block" style="left: 4rem;"></div>

                {companies.map((company) => (
                    <div id={`work-${slugify(company.company)}`} class="flex flex-col md:flex-row md:items-stretch">

                        <div class="flex-none hidden md:block" style="width: 4rem;"></div>

                        <div class="flex flex-row items-center gap-3 md:contents">

                        <div class="flex-none flex items-center md:relative" style="width: 2.5rem;">
                            {company.logo ? (
                                <img src={`/${company.logo}`} alt={company.company} class="rounded object-contain bg-[#020617] md:absolute md:left-0 md:-translate-x-1/2 md:z-10" style="width: 2rem; height: 2rem;" />
                            ) : (
                                <div class="w-3 h-3 rounded-full bg-white md:absolute md:left-0 md:-translate-x-1/2 md:z-10"></div>
                            )}
                        </div>

                        <div class="flex-none flex flex-col justify-center" style="width: 13rem;">
                            <div class="flex items-center">
                                <span class="font-bold text-white leading-snug" style="font-size: 1.1rem;">{company.company}</span>
                            </div>
                            <span class="text-slate-600 mt-1 uppercase tracking-wider" style="font-size: 0.8rem; letter-spacing: 0.08em;">{company.computedDuration}</span>
                            {company.recommendation && (
                                <a href={`/${company.recommendation}`} target="_blank" class="inline-flex items-center gap-1.5 mt-3 px-3 py-1.5 rounded text-slate-300 hover:text-white hover:bg-slate-700 transition-colors border border-slate-700 hover:border-slate-500 self-start" style="font-size: 0.75rem;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                                    Letter of Recommendation
                                </a>
                            )}
                        </div>

                        </div>

                        <div class="flex-none hidden md:flex items-center" style="width: 4rem;">
                            <div class="w-full h-px bg-slate-700"></div>
                        </div>

                        <div class="flex flex-1 items-stretch">

                            <div class="flex-none self-stretch border-l border-t border-b border-slate-700 hidden md:block" style="width: 1.5rem;"></div>

                            <div class="flex-1 flex flex-col">
                                {company.roles.map((role) => {
                                    return (
                                        <div class="flex flex-col gap-3 md:flex-row md:items-start md:gap-10 py-6 px-4 md:px-6">

                                            <div class="w-full md:flex-none md:w-72">
                                                <p class="font-semibold text-white" style="font-size: 1.35rem;">{role.title}</p>
                                                <p class="text-slate-500 mt-1" style="font-size: 0.8rem;">
                                                    {formatYM(role.start)} – {role.current ? "Present" : formatYM(role.end!)} · <span class={`uppercase ${role.type === "full-time" ? "text-blue-400" : role.type === "part-time" ? "text-orange-400" : "text-green-400"}`}>{role.type}</span>
                                                </p>
                                                {role.location && <p class="text-slate-600 italic mt-0.5" style="font-size: 0.69rem;">{role.location}</p>}
                                            </div>

                                            <div class="flex-1 description text-slate-400 text-sm leading-relaxed" set:html={role.description} />

                                        </div>
                                    );
                                })}
                            </div>

                        </div>

                    </div>
                ))}

            </div>

        </div>
    </section>

    <!-- Education -->
    <section id="education" class="w-full py-16 px-4 md:px-8" style="background: #020617;">
        <div class="mx-auto" style="max-width: 1400px;">

            <h1 class="text-3xl font-light text-slate-200 mb-16 tracking-wide">Education</h1>

            <div class="relative flex flex-col gap-12">

                <div class="absolute top-2 bottom-2 w-px bg-slate-700 hidden md:block" style="left: 4rem;"></div>

                {eduData.education.map((entry) => (
                    <div id={`edu-${slugify(entry.institution)}`} class="flex flex-col md:flex-row md:items-center">

                        <div class="flex-none hidden md:block" style="width: 4rem;"></div>

                        <div class="flex flex-row items-center gap-3 md:contents">

                        <div class="flex-none flex items-center md:relative" style="width: 2.5rem;">
                            {entry.logo ? (
                                <img src={`/${entry.logo}`} alt={entry.institution} class="rounded object-contain bg-[#020617] md:absolute md:left-0 md:-translate-x-1/2 md:z-10" style="width: 2rem; height: 2rem;" />
                            ) : (
                                <div class="w-3 h-3 rounded-full bg-white md:absolute md:left-0 md:-translate-x-1/2 md:z-10"></div>
                            )}
                        </div>

                        <div class="flex-none flex flex-col justify-center" style="width: 13rem;">
                            <span class="font-bold text-white leading-snug whitespace-nowrap" style="font-size: 1.1rem;">{entry.institution}</span>
                            {entry.faculty && <span class="text-slate-400 mt-0.5" style="font-size: 1.0rem;">{entry.faculty}</span>}
                        </div>

                        </div>

                        <div class="flex flex-col gap-3 md:flex-row md:items-start md:gap-10 py-2 md:pl-28">
                            <div class="w-full md:flex-none md:w-72">
                                <p class="font-semibold text-white" style="font-size: 1.25rem;">{entry.degree}</p>
                                <p class="text-slate-400 mt-0.5" style="font-size: 0.8rem;">{entry.field}</p>
                                <p class="text-slate-500 mt-1" style="font-size: 0.8rem;">
                                    {entry.start} – {entry.current ? "Present" : entry.end}
                                </p>
                            </div>

                            <div class="flex-1 description text-slate-400 text-sm leading-relaxed" set:html={entry.description} />
                        </div>

                    </div>
                ))}

            </div>

        </div>
    </section>

    <!-- Hire Me Quest -->
    <section id="hire-me-quest" class="w-full py-16 px-8" style="background: #12101e;">
        <div class="mx-auto" style="max-width: 1400px;">
            <div class="flex justify-end">
                <div class="quest-panel">

                    <!-- Title bar -->
                    <div class="quest-title-bar">
                        <div class="quest-icon">
                            <span style="font-size: 1.1rem; line-height:1;">⚔</span>
                        </div>
                        <h2 class="quest-title">Hire Me</h2>
                    </div>
                    <hr class="quest-hr" />

                    <!-- Body -->
                    <div class="quest-body">
                        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas.</p>
                        <p>Vestibulum tortor quam, feugiat vitae, ultricies eget, tempor sit amet, ante. Donec eu libero sit amet quam egestas semper. Aenean ultricies mi vitae est.</p>
                        <p>Mauris placerat eleifend leo. Quisque sit amet est et sapien ullamcorper pharetra. Vestibulum erat wisi, condimentum sed, commodo vitae.</p>

                        <h3 class="quest-section-header">Objectives</h3>
                        <ul class="quest-objectives">
                            <li><span class="quest-check">&#9670;</span> Lorem ipsum dolor sit amet consectetur</li>
                            <li><span class="quest-check">&#9670;</span> Pellentesque habitant morbi tristique senectus</li>
                            <li><span class="quest-check">&#9670;</span> Donec eu libero sit amet quam egestas</li>
                        </ul>

                        <h3 class="quest-section-header">Rewards</h3>
                        <div class="quest-reward-item">
                            <div class="quest-reward-left">
                                <div class="quest-reward-icon">&#129504;</div>
                                <span>Lorem ipsum dolor</span>
                            </div>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="quest-footer-divider"></div>
                    <div class="quest-buttons">
                        <a href="mailto:" class="quest-btn quest-btn-accept">
                            <span class="quest-btn-key">&#8617;</span> Accept
                        </a>
                        <button disabled class="quest-btn quest-btn-decline"><span class="quest-btn-key">Esc</span> Decline</button>
                    </div>

                </div>
            </div>
        </div>
    </section>

</Layout>

<style>
    .description p + p {
        margin-top: 0.75rem;
    }

    /* ── Quest panel ── */
    .quest-panel {
        width: 580px;
        background-color: #c8b084;
        background-image: radial-gradient(ellipse at center, rgba(255,240,200,0.3) 0%, rgba(0,0,0,0.15) 100%);
        border: 1px solid #8a6a3a;
        border-radius: 4px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.55), 0 2px 8px rgba(0,0,0,0.35);
        font-family: Georgia, 'Times New Roman', serif;
        color: #1a0f00;
